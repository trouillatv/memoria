#   OpenAI text-embedding-3-small  ($0.02/M tokens) — multilingue excellent
OPENAI_API_KEY=
#   Voyage AI voyage-3             ($0.06/M tokens) — partenaire Anthropic
VOYAGE_API_KEY=

